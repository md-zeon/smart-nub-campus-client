# Backend API URL (server-side only, not exposed to browser)
BACKEND_URL=http://localhost:5000

# Frontend URL (server-side only)
FRONTEND_URL=http://localhost:3000

# Full API endpoint URL (server-side only)
API_URL=http://localhost:5000/api/v1

# Better Auth endpoint URL (server-side only)
AUTH_URL=http://localhost:5000/api/v1/auth

# Public environment variables (exposed to the browser)
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name

# Node environment
NODE_ENV=development
